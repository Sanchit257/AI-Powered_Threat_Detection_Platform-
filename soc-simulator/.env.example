# Browser-side API base (Vite); nginx serves the SPA on http://localhost and proxies /api
VITE_API_URL=http://localhost/api
# Optional override for WebSocket (defaults derived from VITE_API_URL)
# VITE_WS_URL=ws://localhost/api/ws/alerts

# Required for ml_engine explanation agent (Claude). No key = rule-based MITRE only.
ANTHROPIC_API_KEY=

# Optional: Slack incoming webhook for CRITICAL (severity ≥ 9) alerts from ml_engine.
SLACK_WEBHOOK_URL=

POSTGRES_USER=soc
POSTGRES_PASSWORD=socpassword
POSTGRES_DB=socdb
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://soc:socpassword@db:5432/socdb
SUPABASE_URL=
SUPABASE_ANON_KEY=
