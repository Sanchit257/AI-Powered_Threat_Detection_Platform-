# Browser-side API base (Vite); nginx serves the SPA on http://localhost and proxies /api
VITE_API_URL=http://localhost/api
# Optional override for WebSocket (defaults derived from VITE_API_URL)
# VITE_WS_URL=ws://localhost/api

POSTGRES_USER=soc
POSTGRES_PASSWORD=socpassword
POSTGRES_DB=socdb
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql://soc:socpassword@db:5432/socdb
ANTHROPIC_API_KEY=your_key_here
SUPABASE_URL=
SUPABASE_ANON_KEY=
